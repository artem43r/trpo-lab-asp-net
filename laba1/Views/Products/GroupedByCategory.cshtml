@model IEnumerable<laba1.Models.Product>
@using System.Linq
@{
    ViewData["Title"] = "Товары по категориям";
    // Группировка выполняется прямо в представлении
    var grouped = Model.GroupBy(p => p.Category).OrderBy(g => g.Key);
}
<h1>Товары по категориям</h1>
@if (!Model.Any())
{
    <div class="alert alert-warning">
        В базе данных нет товаров. Добавьте хотя бы один товар через <a aspaction="Create">форму создания</a>.
    </div>
}
else
{
    <div class="accordion" id="categoriesAccordion">
        @{
            int index = 0;
        }
        @foreach (var group in grouped)
        {
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button @(index != 0 ? "collapsed" :
                                 "")"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#collapse@(index)">
                        <strong>@group.Key</strong>
                        <span class="badge bg-secondary ms-2">
                            @group.Count()
                            товаров
                        </span>
                    </button>
                </h2>
                <div id="collapse@(index)"
                     class="accordion-collapse collapse @(index == 0 ? "show" : "")"
                     data-bs-parent="#categoriesAccordion">
                    <div class="accordion-body">
                        <table class="table table-striped table-hover">
                            <thead>
                                <tr>
                                    <th>Название</th>
                                    <th>Цена</th>
                                    <th>В наличии</th>
                                    <th>Дата добавления</th>
                                    <th>Действия</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var product in group)
                                {
                                    <tr>
                                        <td>@product.Name</td>
                                        <td class="text-primary fwbold">@product.Price.ToString("C")</td>
                                        <td>
                                            @if (product.InStock)
                                            {
                                                <span class="badge bg-success">
                                                    В
                                                    наличии
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger">
                                                    Нет в
                                                    наличии
                                                </span>
                                            }
                                        </td>

                                        <td>@product.CreatedDate.ToShortDateString()</td>
                                        <td>
                                            <a asp-action="Details" asp-routeid="@product.Id" class="btn btn-sm btn-info">Детали</a>
                                            <a asp-action="Edit" asp-routeid="@product.Id" class="btn btn-sm btn-warning">Изменить</a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            index++;
        }
    </div>
}
<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">← Назад к списку</a>
    <a asp-action="Create" class="btn btn-primary">Добавить новый товар</a>
</div>
@section Scripts {
    <script>
            // Дополнительная инициализация Bootstrap аккордеона (если нужно)
            document.addEventListener('DOMContentLoaded', function () {
            // Bootstrap 5 аккордеон работает автоматически с data-bs-toggle
            console.log('Страница группировки загружена');
            });
    </script>
}
